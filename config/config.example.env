# pi-remote configuration
# Installed to /etc/pi-remote/config.env and read by hid-keyboard-server.service.
# After editing on the Pi:  sudo systemctl restart hid-keyboard-server

# TCP port the HTTP bridge listens on.
PI_REMOTE_PORT=8800

# Optional shared secret. If non-empty, every request must include
#   ?token=YOURKEY      (query string)  or
#   X-API-Key: YOURKEY  (header)
# The web remote reads the token from its own URL, e.g.
#   http://pi-remote.local:8800/?token=YOURKEY
# Strongly recommended once this is reachable on your LAN.
PI_REMOTE_API_KEY=

# Delay between keystrokes in seconds. Increase if a host drops fast typing.
PI_REMOTE_KEY_DELAY=0.008

# --- Live preview (RTSP -> HLS relay; requires ffmpeg) ---
#PI_REMOTE_FFMPEG=ffmpeg
# HLS segments are written here. Keep it on tmpfs (RAM) to avoid SD-card wear.
#PI_REMOTE_STREAM_DIR=/dev/shm/pi-remote-stream

# --- Paths (defaults shown; normally leave commented) ---
#PI_REMOTE_HTML=/opt/pi-remote/remote.html
#PI_REMOTE_IR_TOOL=/opt/pi-remote/ir_tool.py
#PI_REMOTE_IR_STORE=/var/lib/pi-remote/ir_codes.json
#PI_REMOTE_IR_DEVFILE=/var/lib/pi-remote/ir_device.json
#PI_REMOTE_HID_KBD=/dev/hidg0
#PI_REMOTE_HID_CONSUMER=/dev/hidg1
